# Template for the local MySQL connection parameters used by the pipeline.
# Copy this file to ".my.cnf" and fill in your own credentials. The real
# ".my.cnf" is git-ignored (see .gitignore) and must never be committed.
#
# The pipeline reads the [phd] group via DBI::dbConnect(RMySQL::MySQL(),
# default.file = ".my.cnf", group = "phd") in scripts/0_common.R.

[phd]
database = phd
host     = 127.0.0.1
password = your-password-here
port     = 3306
user     = your-username
